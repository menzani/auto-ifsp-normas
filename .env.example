# --- Modo de desenvolvimento ---
# true  → bypassa Google OAuth, usa usuário fixo de teste
# false → fluxo OAuth real
MOCK_AUTH=true

# true  → simula respostas da API do Bookstack localmente
# false → conecta ao normas.ifsp.edu.br
MOCK_BOOKSTACK=true

# true  → usa diretório local ./data/ em vez do S3
MOCK_S3=true

# --- Sessão (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=troque-esta-chave-em-producao

# --- Google OAuth (necessário quando MOCK_AUTH=false)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Domínio permitido do Google Workspace (ex: ifsp.edu.br)
GOOGLE_ALLOWED_DOMAIN=ifsp.edu.br

# --- Bookstack (necessário quando MOCK_BOOKSTACK=false)
BOOKSTACK_BASE_URL=https://normas.ifsp.edu.br
BOOKSTACK_TOKEN_ID=
BOOKSTACK_TOKEN_SECRET=

# --- AWS (necessário quando MOCK_S3=false)
AWS_REGION=us-east-1
S3_BUCKET_NAME=
# URL pré-assinada válida por 1 ano (segundos)
S3_PRESIGNED_URL_EXPIRY=31536000

# --- Bedrock (LLM para FAQ — fase 3)
# Claude 3.5 Haiku — disponível em us-east-1 e us-west-2
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# --- Usuários administradores iniciais (separados por vírgula)
# Esses e-mails recebem papel "admin" automaticamente no primeiro login.
ADMIN_EMAILS=

# --- Limites de segurança
MAX_UPLOAD_SIZE_MB=30
MAX_UPLOADS_PER_USER_PER_HOUR=10
LAMBDA_RESERVED_CONCURRENCY=15
