@startuml Arquitetura: auto.normas.ifsp.edu.br

title Arquitetura: auto.normas.ifsp.edu.br

' Bibliotecas AWS para PlantUML
' Caminho local: ~/docs/plantuml-libs/aws-icons-for-plantuml/dist
!define AWSPuml plantuml-libs/aws-icons-for-plantuml/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/AWSSimplified.puml
!include AWSPuml/Compute/EC2Instance.puml
!include AWSPuml/NetworkingContentDelivery/Route53.puml
!include AWSPuml/Storage/SimpleStorageService.puml
!include AWSPuml/ArtificialIntelligence/Bedrock.puml
!include AWSPuml/SecurityIdentityCompliance/IdentityAccessManagementRole.puml
!include AWSPuml/Groups/AWSCloud.puml
!include AWSPuml/Groups/VPC.puml

hide stereotype
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80

actor "Usuário\n@ifsp.edu.br" as user

node "Google OAuth\n(Workspace Institucional)" as oauth
node "Bookstack\n(Wiki de Normas)" as bookstack

AWSCloudGroup(cloud, "AWS Cloud") {

    Route53(r53, "Route 53\n(DNS)", "DNS")

    VPCGroup(vpc, "VPC Privada") {
        EC2Instance(ec2, "EC2 t3.micro\nnginx + FastAPI\n(uvicorn · systemd)", "EC2")
    }

    together {
        SimpleStorageService(s3, "S3\nPDFs · metadados\nauditoria · revogações", "S3")
        Bedrock(bedrock, "Amazon Bedrock\nClaude Sonnet 4.6\nVisão · FAQ · Resumo", "Bedrock")
    }

    IdentityAccessManagementRole(iam, "IAM Role\nS3 + Bedrock +\nCost Explorer", "IAM")
}

' Fluxo principal: usuário → DNS → EC2
' 1. Browser consulta DNS → Route 53 retorna o IP do EC2
user ..> r53 : DNS
r53 ..> ec2 : IP elástico
' 2. Browser conecta ao EC2 via HTTPS
user -down-> ec2 : HTTPS (443)

' EC2 → serviços externos (direita)
ec2 -right-> oauth : OAuth 2.0
ec2 -right-> bookstack : API REST

' EC2 → serviços AWS (baixo) — labels removidos, ícones já comunicam
ec2 -down-> s3
ec2 -down-> bedrock

' IAM → permissões (tracejado)
iam ..> s3
iam ..> bedrock

note right of bedrock
  Pipelines assíncronos (threading.Thread):
  • Upload: Vision por lotes → FAQ → Bookstack
  • Revogação: resumo (IA) → Revogadas → remove
end note

@enduml
