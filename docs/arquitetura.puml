@startuml Arquitetura: auto.normas.ifsp.edu.br

title Arquitetura: auto.normas.ifsp.edu.br

' Bibliotecas AWS para PlantUML
' Caminho local: ~/docs/plantuml-libs/aws-icons-for-plantuml/dist
!define AWSPuml plantuml-libs/aws-icons-for-plantuml/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/AWSSimplified.puml
!include AWSPuml/Compute/EC2.puml
!include AWSPuml/Compute/EC2Instance.puml
!include AWSPuml/NetworkingContentDelivery/Route53.puml
!include AWSPuml/Storage/SimpleStorageService.puml
!include AWSPuml/ArtificialIntelligence/Bedrock.puml
!include AWSPuml/SecurityIdentityCompliance/IdentityAccessManagementRole.puml
!include AWSPuml/General/Internet.puml
!include AWSPuml/Groups/AWSCloud.puml
!include AWSPuml/Groups/VPC.puml

hide stereotype
skinparam linetype ortho

' Atores externos
actor "Usuário\n@ifsp.edu.br" as user
node "Google OAuth\n(Workspace Institucional)" as oauth
node "Bookstack\n(Wiki de Normas)" as bookstack

AWSCloudGroup(cloud, "AWS Cloud") {

    Route53(r53, "DNS", "Route 53")
    IdentityAccessManagementRole(iam, "IAM Role\n(permissões mínimas)", "Credenciais da instância")
    SimpleStorageService(s3, "Armazenamento\n(PDFs, metadados,\nregistro de revogações)", "S3")
    Bedrock(bedrock, "IA Generativa\n(Claude Haiku)", "Amazon Bedrock")

    VPCGroup(vpc, "VPC Privada") {
        EC2Instance(ec2, "EC2 (Free Tier)\nnginx + FastAPI\n(uvicorn, systemd)", "EC2")
    }
}

user --> r53 : resolução DNS
r53 ..> ec2 : aponta para IP elástico
user --> ec2 : HTTPS (443)

ec2 --> oauth : autenticação OAuth 2.0
ec2 --> s3 : PDFs e metadados
ec2 --> bedrock : geração de FAQ e resumos
ec2 --> bookstack : criação e gestão de livros

iam ..> s3 : acesso via instância
iam ..> bedrock : acesso via instância

note right of ec2
  Pipelines assíncronos
  (threading.Thread):
  - Upload: extração PDF → FAQ (IA) → Bookstack
  - Revogação: busca → resumo (IA) → Revogadas → remove original
end note

@enduml
